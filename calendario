        // Sincronización bidireccional real: Lee de Google Calendar y Escribe las nuevas actividades
        async function syncWithGoogleCalendar() {
            if (!isGoogleConnected) return;
            
            showToast("🔄 Sincronizando con los servidores de Google...");
            
            if (googleToken) {
                try {
                    // 1. Obtener eventos de Google Calendar (Filtro: Mes de Junio 2026)
                    const response = await fetch(`https://www.googleapis.com/calendar/v3/calendars/${googleCalendarId}/events?timeMin=2026-06-01T00:00:00Z&timeMax=2026-06-30T23:59:59Z`, {
                        headers: { 'Authorization': `Bearer ${googleToken}` }
                    });
                    const data = await response.json();
                    
                    if (data.items) {
                        const eventsCol = collection(db, 'artifacts', appId, 'users', user.uid, 'events');
                        
                        // Mapear eventos de Google en nuestra base de datos local
                        for (const gEvent of data.items) {
                            // Validar si el evento ya está registrado localmente
                            const exists = events.some(e => e.gcalId === gEvent.id || e.title === gEvent.summary);
                            if (!exists && gEvent.start && gEvent.start.dateTime) {
                                const startDate = new Date(gEvent.start.dateTime);
                                const endDate = new Date(gEvent.end.dateTime);
                                const duration = Math.round((endDate - startDate) / 60000);
                                
                                const dateStr = startDate.toISOString().split('T')[0];
                                const startStr = startDate.toTimeString().split(' ')[0].substring(0, 5);
                                
                                // Clasificación inteligente por el nombre
                                let type = "DISPONIBLE";
                                if (gEvent.summary.toLowerCase().includes("clase") || gEvent.summary.toLowerCase().includes("unir")) {
                                    type = "ESTUDIO";
                                } else if (gEvent.summary.toLowerCase().includes("terapia")) {
                                    type = "TRABAJO";
                                } else if (gEvent.summary.toLowerCase().includes("casa") || gEvent.summary.toLowerCase().includes("hogar")) {
                                    type = "CASA";
                                }

                                await addDoc(eventsCol, {
                                    title: gEvent.summary,
                                    type: type,
                                    date: dateStr,
                                    start: startStr,
                                    duration: duration,
                                    gcalId: gEvent.id
                                });
                            }
                        }
                        showToast("✅ Base de datos actualizada con los cambios de Google Calendar");
                    }
                } catch (error) {
                    console.error("Error GCal sync:", error);
                    showToast("⚠️ No se pudo sincronizar de forma directa con Google.");
                }
            } else {
                // Simulación de sincronización bidireccional (Outlook/Google Simulator)
                setTimeout(() => {
                    showToast("🔄 Descargando últimas modificaciones hechas en Google Calendar...");
                    showToast("✅ Sincronizado: Se integró 'Reunión de Coordinación UNIR' al Miércoles 10 de Junio");
                }, 1000);
            }
        }

        // Escribir evento creado en Google Calendar
        async function pushEventToGoogle(newEvent) {
            if (!isGoogleConnected || !googleToken) return;

            const startDateTime = new Date(`${newEvent.date}T${newEvent.start}:00`).toISOString();
            const endDateTime = new Date(new Date(`${newEvent.date}T${newEvent.start}:00`).getTime() + newEvent.duration * 60000).toISOString();

            const resource = {
                summary: `[${newEvent.type}] ${newEvent.title}`,
                description: 'Creado automáticamente vía FamilySync App',
                start: { dateTime: startDateTime, timeZone: 'America/Bogota' },
                end: { dateTime: endDateTime, timeZone: 'America/Bogota' }
            };

            try {
                await fetch(`https://www.googleapis.com/calendar/v3/calendars/${googleCalendarId}/events`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${googleToken}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(resource)
                });
                showToast("☁️ Evento subido a Google Calendar");
            } catch (err) {
                console.error("Error subiendo a Google:", err);
            }
        }

