                        if (e.type === 'ESTUDIO') c = "bg-[#ddebf7] text-[#1f4e79] border border-[#9bc2e6]";
                        else if (e.type === 'TRABAJO') c = "bg-[#fce4d6] text-[#c65911] border border-[#f4b183]";
                        else if (e.type === 'CASA') c = "bg-[#e2f0d9] text-[#385723] border border-[#a9d18e]";

                        textBlocksList += `
                            <div onclick="event.stopPropagation(); openEditEventModal('${e.id}')" class="text-[7.5px] font-bold truncate leading-none py-1 px-1 rounded border overflow-hidden whitespace-nowrap block cursor-pointer hover:opacity-85 transition ${c}" title="${e.title}">
                                ${e.title}
                            </div>
                        `;
                    });

                    if (dayEvents.length > 2) {
                        textBlocksList += `
                            <div class="text-[7px] text-[#1f4e79] font-bold text-center bg-blue-50/60 rounded py-0.5 border border-blue-100">
                                + ${dayEvents.length - 2} más
                            </div>
                        `;
                    }
                }
                textBlocksList += '</div>';

                cell.innerHTML = `
                    <span class="font-bold text-slate-500 text-[10px] bg-slate-100 rounded px-1.5 py-0.5">${i}</span>
                    ${textBlocksList}
                `;
                container.appendChild(cell);
            }
        }

        function showDayDetailsInMonth(dateStr) {
            const title = document.getElementById('details-panel-title');
            const dateLabel = document.getElementById('details-panel-date');
            const listContainer = document.getElementById('details-panel-list');

            const formattedDate = new Date(dateStr + "T00:00:00").toLocaleDateString('es-ES', {
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            });

            title.innerText = `Agenda del Día`;
            dateLabel.innerText = formattedDate;

            const dayEvents = events.filter(e => e.date === dateStr);
            dayEvents.sort((a, b) => a.start.localeCompare(b.start));

            listContainer.innerHTML = '';

            if (dayEvents.length === 0) {
                listContainer.innerHTML = `
                    <div class="text-center py-6 text-slate-400 text-xs">
                        <i class="fa-solid fa-mug-hot text-amber-500 text-xl mb-1"></i>
                        <p>No hay actividades para este día.</p>
                        <button onclick="openAddEventModalWithTime('${dateStr}', '08:00')" class="text-[10px] text-blue-600 font-bold hover:underline mt-1.5 block mx-auto">Agregar nueva actividad</button>
                    </div>
                `;
                return;
            }

            dayEvents.forEach(e => {
                let badgeColor = "bg-slate-100 text-slate-700";
                if (e.type === 'ESTUDIO') badgeColor = "bg-[#ddebf7] text-[#1f4e79] border border-[#9bc2e6]";
                else if (e.type === 'TRABAJO') badgeColor = "bg-[#fce4d6] text-[#c65911] border border-[#f4b183]";
                else if (e.type === 'CASA') badgeColor = "bg-[#e2f0d9] text-[#385723] border border-[#a9d18e]";

                const endTime = calculateEndTime(e.start, e.duration);
                listContainer.innerHTML += `
                    <div onclick="openEditEventModal('${e.id}')" class="flex items-center justify-between p-3 rounded-2xl border border-slate-100 bg-slate-50/50 cursor-pointer hover:bg-slate-100 transition">
                        <div class="flex items-center gap-2.5 max-w-[85%]">
                            <span class="text-[9px] font-bold px-2 py-1 rounded-lg ${badgeColor}">${e.type}</span>
                            <div class="truncate">
                                <p class="text-xs font-bold text-slate-800 truncate">${e.title}</p>
                                <p class="text-[10px] text-slate-500 font-mono">${e.start} - ${endTime} (${e.duration} min)</p>
                            </div>
                        </div>
                        <span class="text-[9px] text-[#1f4e79] font-bold hover:underline">Modificar</span>
                    </div>
                `;
            });
        }

        function calculateStatistics() {
            const container = document.getElementById('stats-bars-container');
            container.innerHTML = '';

            let mins = { ESTUDIO: 0, TRABAJO: 0, CASA: 0 };
            events.forEach(e => { if (mins[e.type] !== undefined) mins[e.type] += e.duration; });

            const colors = { ESTUDIO: "bg-[#1f4e79]", TRABAJO: "bg-[#c65911]", CASA: "bg-[#385723]" };
            const labels = { ESTUDIO: "Estudio UNIR / Trading", TRABAJO: "Terapias Katerine", CASA: "Hogar y Logística" };

            Object.keys(mins).forEach(key => {
                const hrs = (mins[key] / 60).toFixed(1);
                const percent = Math.min((mins[key] / 1200) * 100, 100);

                container.innerHTML += `
                    <div class="space-y-1">
                        <div class="flex justify-between text-xs font-bold">
                            <span class="text-slate-600">${labels[key]}</span>
                            <span class="text-slate-900 font-mono">${hrs} Horas</span>
                        </div>
                        <div class="w-full bg-slate-100 h-3 rounded-full overflow-hidden border border-slate-200">
                            <div class="${colors[key]} h-full rounded-full" style="width: ${percent}%"></div>
                        </div>
                    </div>
                `;
            });
        }

        // EXPORTACIÓN PREMIUM CON ESTÉTICA DE LA FOTO
        window.generateImage = function() {
            const view = document.getElementById('export-view-select').value;
            const container = document.getElementById('capture-container');
            const renderArea = document.getElementById('capture-render-area');
            const subTag = document.getElementById('capture-sub-tag');

            container.classList.remove('hidden');
            renderArea.innerHTML = '';

            if (view === 'week') {
                subTag.innerText = "Vista Semanal";
                const weekStart = new Date(weeks[currentWeekIndex].start + "T00:00:00");
                const daysDates = [];
                for (let i = 0; i < 6; i++) {
                    const day = new Date(weekStart);
                    day.setDate(weekStart.getDate() + i);
                    daysDates.push(day.toISOString().split('T')[0]);
                }

                let tableRows = '';
                dayHoursList.forEach(hour => {
                    let rowCells = `<td style="padding: 6px; font-weight: bold; color: #64748b; border-bottom: 1px solid #e2e8f0; font-family: monospace;">${hour}</td>`;
                    daysDates.forEach(date => {
                        const matchedEvents = events.filter(e => e.date === date);
                        let activeEvent = null;
                        for (let e of matchedEvents) {
                            const [evH] = e.start.split(':');
                            const [targetH] = hour.split(':');
                            if (evH === targetH) {
                                activeEvent = e;
                                break;
                            }
                        }

                        if (activeEvent) {
                            let cellStyle = "background-color: #f1f5f9; color: #475569;";
                            if (activeEvent.type === 'ESTUDIO') cellStyle = "background-color: #ddebf7; color: #1f4e79; font-weight: bold; border: 1px solid #9bc2e6;";
                            else if (activeEvent.type === 'TRABAJO') cellStyle = "background-color: #fce4d6; color: #c65911; font-weight: bold; border: 1px solid #f4b183;";
                            else if (activeEvent.type === 'CASA') cellStyle = "background-color: #e2f0d9; color: #385723; font-weight: bold; border: 1px solid #a9d18e;";

                            rowCells += `
                                <td style="padding: 4px; border-bottom: 1px solid #e2e8f0;">
                                    <div style="padding: 6px 4px; border-radius: 6px; font-size: 8px; text-align: center; text-transform: uppercase; ${cellStyle}">
                                        ${activeEvent.title}
                                    </div>
                                </td>
                            `;
                        } else {
                            rowCells += `<td style="padding: 4px; border-bottom: 1px solid #e2e8f0; text-align: center; color: #cbd5e1; font-size: 8px;">—</td>`;
                        }
                    });
                    tableRows += `<tr>${rowCells}</tr>`;
                });

                renderArea.innerHTML = `
                    <div style="font-size: 13px; font-weight: bold; color: #1f4e79; margin-bottom: 12px; border-bottom: 2px solid #1f4e79/30; padding-bottom: 4px; text-transform: uppercase;">Cuadrícula Horaria Semanal</div>
                    <table style="width: 100%; border-collapse: collapse; font-size: 9px; color: #334155;">
                        <thead>
                            <tr style="background-color: #f1f5f9; border-bottom: 2px solid #cbd5e1;">
                                <th style="padding: 8px; text-align: left; color: #475569;">HORA</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">LUNES</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">MARTES</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">MIÉRCOLES</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">JUEVES</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">VIERNES</th>
                                <th style="padding: 8px; text-align: center; color: #475569;">SÁBADO</th>
                            </tr>
                        </thead>
                        <tbody>${tableRows}</tbody>
                    </table>
                `;
            } else {
                subTag.innerText = "Mes de Junio 2026";
                let html = `
                    <div style="font-size: 13px; font-weight: bold; color: #1f4e79; margin-bottom: 12px; border-bottom: 2px solid #1f4e79/30; padding-bottom: 4px; text-transform: uppercase;">Calendario de Actividades Mensuales (Junio 2026)</div>
                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; text-align: left; font-size: 9px;">
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Lunes</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Martes</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Miércoles</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Jueves</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Viernes</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Sábado</div>
                        <div style="text-align: center; font-weight: bold; color: #64748b; padding-bottom: 4px; border-bottom: 1px solid #cbd5e1;">Domingo</div>
                `;
                
                for (let i = 1; i <= 30; i++) {
                    const dayStr = String(i).padStart(2, '0');
                    const dateStr = `2026-06-${dayStr}`;
                    const dayEvents = events.filter(e => e.date === dateStr);
                    dayEvents.sort((a, b) => a.start.localeCompare(b.start));

                    let eventsHtml = '';
                    dayEvents.forEach(e => {
                        let badgeStyle = "background-color: #f1f5f9; color: #475569; border-left: 2px solid #cbd5e1;";
                        if (e.type === 'ESTUDIO') badgeStyle = "background-color: #ddebf7; color: #1f4e79; border-left: 2px solid #9bc2e6;";
                        else if (e.type === 'TRABAJO') badgeStyle = "background-color: #fce4d6; color: #c65911; border-left: 2px solid #f4b183;";
                        else if (e.type === 'CASA') badgeStyle = "background-color: #e2f0d9; color: #385723; border-left: 2px solid #a9d18e;";

                        eventsHtml += `
                            <div style="font-size: 7.5px; padding: 2px 3px; margin-top: 2.5px; border-radius: 4px; font-weight: bold; ${badgeStyle} overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                ${e.start} - ${e.title}
                            </div>
                        `;
                    });

                    html += `
                        <div style="border: 1px solid #e2e8f0; background-color: #ffffff; padding: 6px; rounded: 8px; min-height: 85px;">
                            <span style="font-weight: bold; color: #94a3b8; font-size: 9px;">${i}</span>
                            <div style="margin-top: 4px; display: flex; flex-direction: column; gap: 2px;">${eventsHtml}</div>
                        </div>
                    `;
                }
                html += `</div>`;
                renderArea.innerHTML = html;
            }

            html2canvas(container, {
                scale: 2,
                useCORS: true
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = `FamilySync_Agenda_${view === 'week' ? 'Semanal' : 'Mensual'}.png`;
                link.href = canvas.toDataURL();
                link.click();
                container.classList.add('hidden');
                showToast("📸 ¡Agenda exportada en formato de imagen física de alta gama!");
            });
        }

        window.openAddEventModalWithTime = function(date, hour) {
            editingEventId = null;
            document.getElementById('modal-title').innerText = "Nueva Actividad";
            document.getElementById('event-form').reset();
            
            document.getElementById('event-date').value = date;
            document.getElementById('event-start').value = hour;
            document.getElementById('modal-delete-btn').classList.add('hidden');
            document.getElementById('add-event-modal').classList.remove('hidden');
        }

        window.openAddEventModal = function() {
            editingEventId = null;
            document.getElementById('modal-title').innerText = "Nueva Actividad";
            document.getElementById('event-form').reset();
            document.getElementById('event-date').value = selectedDate;
            
            document.getElementById('modal-delete-btn').classList.add('hidden');
            document.getElementById('add-event-modal').classList.remove('hidden');
        }

        window.openEditEventModal = function(id) {
            const event = events.find(e => e.id === id);
            if (!event) return;

            editingEventId = id;
            document.getElementById('modal-title').innerText = "Editar Actividad";
            document.getElementById('event-title').value = event.title;
            document.getElementById('event-type').value = event.type;
            document.getElementById('event-date').value = event.date;
            document.getElementById('event-start').value = event.start;
            document.getElementById('event-duration').value = event.duration;

            document.getElementById('modal-delete-btn').classList.remove('hidden');
            document.getElementById('add-event-modal').classList.remove('hidden');
        }

        window.closeAddEventModal = function() {
            document.getElementById('add-event-modal').classList.add('hidden');
            document.getElementById('event-form').reset();
            editingEventId = null;
        }

        window.saveEvent = async function(e) {
            e.preventDefault();
            const title = document.getElementById('event-title').value;
            const type = document.getElementById('event-type').value;
            const date = document.getElementById('event-date').value;
            const start = document.getElementById('event-start').value;
            const duration = parseInt(document.getElementById('event-duration').value);

            const eventsCol = collection(db, 'artifacts', appId, 'users', user.uid, 'events');

            const payload = { title, type, date, start, duration };

            if (editingEventId) {
                const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'events', editingEventId);
                await updateDoc(docRef, payload);
                showToast("✅ Actividad modificada con éxito en la Nube");
            } else {
                const docRef = await addDoc(eventsCol, payload);
                showToast("✅ Actividad guardada con éxito en la Nube");
                if (isGoogleConnected) {
                    pushEventToGoogle({ id: docRef.id, ...payload });
                }
            }
            
            closeAddEventModal();
            refreshAllViews();
        }

        window.deleteEvent = async function(id) {
            const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'events', id);
            await deleteDoc(docRef);
            showToast("🗑️ Actividad eliminada de la Nube");
            refreshAllViews();
        }

        window.deleteCurrentEvent = function() {
            if (editingEventId) {
                deleteEvent(editingEventId);
                closeAddEventModal();
            }
        }

        function refreshAllViews() {
            renderEvents();
            renderWeeklyGrid();
            renderMonthlyGrid();
            showDayDetailsInMonth(selectedDate);
        }

        function calculateEndTime(startStr, durationMin) {
            const [hrs, mins] = startStr.split(':').map(Number);
            let totalMins = hrs * 60 + mins + durationMin;
            let endHrs = Math.floor(totalMins / 60) % 24;
            let endMins = totalMins % 60;
            return `${String(endHrs).padStart(2, '0')}:${String(endMins).padStart(2, '0')}`;
        }

        function showToast(message) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = "bg-white text-slate-800 border border-[#dfd5be] py-3.5 px-4 rounded-2xl text-xs font-bold shadow-xl flex items-center gap-2.5 transform translate-y-2 opacity-0 transition-all duration-300";
            toast.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-600"></i> ${message}`;
            container.appendChild(toast);
            setTimeout(() => { toast.classList.remove('translate-y-2', 'opacity-0'); }, 10);
            setTimeout(() => {
                toast.classList.add('translate-y-2', 'opacity-0');
                setTimeout(() => { toast.remove(); }, 300);
            }, 3000);
        }

        // Asignación de triggers de Google APIs al cargarse el DOM
        window.addEventListener('DOMContentLoaded', () => {
            initGoogleOAuth();
            document.getElementById('gcal-connect-btn').addEventListener('click', connectToGoogle);
            document.getElementById('google-sync-now-btn').addEventListener('click', syncWithGoogleCalendar);
            renderWeekNav();
            renderWeeklyGrid();
            renderMonthlyGrid();
            showDayDetailsInMonth(selectedDate);
        });
    </script>
</body>
</html>
