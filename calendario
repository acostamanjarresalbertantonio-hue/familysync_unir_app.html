<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FamilySync - Agenda Familiar Premium</title>
    <!-- Tailwind CSS para diseño fluido y moderno -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome para iconos ejecutivos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- html2canvas para generación de imágenes nativas de alta calidad -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <!-- Google APIs para Autenticación de Google Calendar y Sincronización en Tiempo Real -->
    <script src="https://apis.google.com/js/api.js" async defer></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #2b231a; /* Madera oscura de fondo ambiental */
            background-image: radial-gradient(rgba(0, 0, 0, 0.4) 1px, transparent 0);
            background-size: 24px 24px;
        }

        .planner-header {
            font-family: 'Playfair Display', serif;
        }

        /* Simulación de textura de papel pergamino mate que no daña la vista */
        .paper-texture {
            background-color: #f5eedf;
            background-image: radial-gradient(#dfd7c2 1.2px, transparent 0);
            background-size: 20px 20px;
        }

        /* Estilo para los espirales de la agenda física en el exportador */
        .spiral-ring {
            background: linear-gradient(90deg, #8a8a8a 0%, #dcdcdc 50%, #5e5e5e 100%);
            border-radius: 4px;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.15);
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #eae3d2;
        }
        ::-webkit-scrollbar-thumb {
            background: #c7bda6;
            border-radius: 4px;
        }
    </style>
</head>
<body class="text-[#2c261e] min-h-screen flex justify-center p-0 sm:p-4">

    <!-- CONTENEDOR DE LA APLICACIÓN ESTILO AGENDA MÓVIL PREMIUM -->
    <div class="w-full max-w-md bg-[#f5eedf] min-h-screen sm:min-h-[850px] sm:my-4 flex flex-col shadow-2xl relative border border-[#dfd5be] sm:rounded-3xl overflow-hidden">
        
        <!-- HEADER DE LA APP (Estilo Corporativo de Lujo) -->
        <header class="bg-[#ebdcb9] p-4 border-b border-[#dfd5be] sticky top-0 z-30 flex justify-between items-center shadow-sm">
            <div class="flex items-center gap-3">
                <div class="bg-[#1f4e79] text-white p-2.5 rounded-2xl shadow-md">
                    <i class="fa-solid fa-feather-pointed text-lg"></i>
                </div>
                <div>
                    <h1 class="text-base font-bold text-[#1f4e79] tracking-wide planner-header">FamilySync</h1>
                    <p class="text-[9px] text-slate-600 font-bold uppercase tracking-widest">UNIR & Cloud Edition</p>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                <!-- Botón de Sincronización Manual con Google Calendar -->
                <button id="google-sync-now-btn" class="bg-[#f5eedf] hover:bg-[#eae3d2] text-slate-700 p-2.5 rounded-xl transition border border-[#dfd5be] shadow-sm hidden" title="Sincronizar Google Calendar">
                    <i class="fa-solid fa-arrows-rotate text-sm"></i>
                </button>
                <!-- Botón de Exportación Premium -->
                <button onclick="openExportModal()" class="bg-[#f5eedf] hover:bg-[#eae3d2] text-slate-700 p-2.5 rounded-xl transition border border-[#dfd5be] shadow-sm" title="Exportar Agenda">
                    <i class="fa-solid fa-print text-sm"></i>
                </button>
                <!-- Badge Estado Activo -->
                <div id="cloud-status-badge" class="flex items-center gap-1.5 bg-amber-500/10 text-amber-700 px-2.5 py-1.5 rounded-xl text-[9px] font-bold border border-amber-300 shadow-sm">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                    <span id="cloud-status-text">Conectando...</span>
                </div>
            </div>
        </header>

        <!-- SUBHEADER NAVEGACIÓN SEMANAL -->
        <div id="calendar-week-nav" class="bg-[#f5eedf]/95 backdrop-blur-md p-3 border-b border-[#dfd5be] flex justify-between items-center sticky top-[69px] z-20">
            <button onclick="prevWeek()" class="p-2 hover:bg-[#eae3d2] rounded-lg text-slate-500 hover:text-slate-800 transition">
                <i class="fa-solid fa-chevron-left text-xs"></i>
            </button>
            <span id="current-week-label" class="font-bold text-[10px] tracking-widest text-slate-600 uppercase">Semana 1 (Jun 08 - Jun 14)</span>
            <button onclick="nextWeek()" class="p-2 hover:bg-[#eae3d2] rounded-lg text-slate-500 hover:text-slate-800 transition">
                <i class="fa-solid fa-chevron-right text-xs"></i>
            </button>
        </div>

        <!-- PESTAÑAS DE NAVEGACIÓN INTERACTIVA -->
        <div class="px-4 pt-4 bg-[#f5eedf]">
            <div class="grid grid-cols-4 bg-[#eae3d2] p-1 rounded-2xl border border-[#dfd5be]/40 text-center">
                <button onclick="switchView('day')" id="tab-day" class="py-2.5 text-[10px] font-bold rounded-xl transition bg-[#f5eedf] text-slate-900 shadow-sm border border-[#dfd5be]/60">
                    DÍA
                </button>
                <button onclick="switchView('week')" id="tab-week" class="py-2.5 text-[10px] font-bold rounded-xl transition text-slate-600 hover:text-slate-900">
                    SEMANA
                </button>
                <button onclick="switchView('month')" id="tab-month" class="py-2.5 text-[10px] font-bold rounded-xl transition text-slate-600 hover:text-slate-900">
                    MES
                </button>
                <button onclick="switchView('stats')" id="tab-stats" class="py-2.5 text-[10px] font-bold rounded-xl transition text-slate-600 hover:text-slate-900">
                    CONEXIÓN
                </button>
            </div>
        </div>

        <!-- CUERPO DE CONTENIDO CON DESPLAZAMIENTO -->
        <main class="flex-1 overflow-y-auto pb-24 p-4 space-y-4 paper-texture">

            <!-- 1. VISTA DIARIA -->
            <div id="view-day" class="space-y-4">
                <div class="flex justify-between gap-1 overflow-x-auto pb-1" id="day-selector"></div>
                <div class="bg-white/80 border border-[#dfd5be] rounded-3xl p-4 shadow-sm space-y-3">
                    <div class="flex justify-between items-center border-b border-slate-200 pb-2">
                        <h3 class="text-xs font-bold tracking-wider text-slate-700 uppercase planner-header"><i class="fa-solid fa-list-check text-[#1f4e79] mr-2"></i>Línea de Tiempo Diaria</h3>
                        <span class="text-[9px] text-slate-400">Toca las horas libres para agregar</span>
                    </div>
                    <div class="divide-y divide-slate-100" id="day-timeline-container"></div>
                </div>
            </div>

            <!-- 2. VISTA SEMANAL -->
            <div id="view-week" class="hidden space-y-4">
                <div class="bg-white/90 p-3 rounded-2xl border border-[#dfd5be] shadow-sm overflow-hidden">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-xs font-bold tracking-wider text-slate-700 uppercase planner-header"><i class="fa-solid fa-table-cells text-[#1f4e79] mr-2"></i>Cuadrícula Semanal</h3>
                        <span class="text-[9px] text-slate-400 bg-slate-100 px-2 py-0.5 rounded">Toca cualquier celda</span>
                    </div>
                    <div class="overflow-x-auto w-full">
                        <table class="w-full text-left border-collapse min-w-[650px] text-[11px]">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="py-2 pr-2 font-bold text-slate-400 w-16">HORA</th>
                                    <th class="py-2 text-center font-bold text-slate-600">LUN</th>
                                    <th class="py-2 text-center font-bold text-slate-600">MAR</th>
                                    <th class="py-2 text-center font-bold text-slate-600">MIÉ</th>
                                    <th class="py-2 text-center font-bold text-slate-600">JUE</th>
                                    <th class="py-2 text-center font-bold text-slate-600">VIE</th>
                                    <th class="py-2 text-center font-bold text-slate-600">SÁB</th>
                                </tr>
                            </thead>
                            <tbody id="week-grid-body" class="divide-y divide-slate-100"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 3. VISTA MENSUAL (ESTILO GOOGLE CALENDAR / OUTLOOK) -->
            <div id="view-month" class="hidden space-y-4">
                <div class="bg-white/90 p-4 rounded-2xl border border-[#dfd5be] shadow-sm space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-200 pb-3">
                        <h3 class="text-xs font-bold tracking-wider text-slate-700 uppercase planner-header"><i class="fa-solid fa-calendar-days text-[#1f4e79] mr-2"></i>Vista de Mes Completo</h3>
                        <span class="text-xs font-bold text-[#1f4e79] bg-[#ddebf7] px-3 py-1 rounded-full border border-[#9bc2e6]">Junio 2026</span>
                    </div>

                    <div class="grid grid-cols-7 gap-1 text-center text-[10px]">
                        <div class="text-slate-400 font-bold py-1">L</div>
                        <div class="text-slate-400 font-bold py-1">M</div>
                        <div class="text-slate-400 font-bold py-1">M</div>
                        <div class="text-slate-400 font-bold py-1">J</div>
                        <div class="text-slate-400 font-bold py-1">V</div>
                        <div class="text-slate-400 font-bold py-1 text-red-500">S</div>
                        <div class="text-slate-400 font-bold py-1 text-red-500">D</div>
                        <div id="month-days-container" class="contents"></div>
                    </div>
                </div>

                <div id="month-day-details-panel" class="bg-white/90 p-4 rounded-2xl border border-[#dfd5be] shadow-sm space-y-3">
                    <div class="flex justify-between items-center border-b border-slate-200 pb-2">
                        <h4 class="text-xs font-bold text-slate-700 uppercase tracking-wider" id="details-panel-title">Detalles del Día</h4>
                        <span class="text-[10px] text-slate-500 font-mono" id="details-panel-date">Selecciona un día en la cuadrícula</span>
                    </div>
                    <div class="space-y-2.5" id="details-panel-list">
                        <p class="text-xs text-slate-400 text-center py-4">Toca un día en la cuadrícula superior para cargar su agenda completa aquí.</p>
                    </div>
                </div>
            </div>

            <!-- 4. PESTAÑA DE CONEXIÓN Y ESTADÍSTICAS -->
            <div id="view-stats" class="hidden space-y-4">
                <!-- Panel de Conexión de Google Calendar -->
                <div class="bg-white/90 p-5 rounded-2xl border border-[#dfd5be] shadow-sm space-y-4">
                    <h3 class="text-xs font-bold text-slate-700 uppercase tracking-wider planner-header"><i class="fa-brands fa-google text-blue-600 mr-2"></i>Sincronización Bidireccional</h3>
                    <p class="text-xs text-slate-500 leading-relaxed">Al conectar tu cuenta de Google, cualquier cambio que hagas en tu celular o PC se reflejará de inmediato en tu calendario personal y viceversa.</p>
                    
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 text-xs space-y-2.5">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-500">Estado de Google Calendar:</span>
                            <span id="gcal-status-text" class="font-bold text-red-600">Desconectado</span>
                        </div>
                        <div class="text-[10px] text-slate-400">
                            *Nota: Para sincronización en tiempo real, puedes ingresar tu Google OAuth Client ID o utilizar nuestro simulador inteligente.
                        </div>
                    </div>

                    <div id="gcal-actions-container" class="space-y-2">
                        <button id="gcal-connect-btn" class="w-full bg-[#1f4e79] hover:bg-[#1a4165] text-white font-bold text-xs py-3 rounded-xl transition flex items-center justify-center gap-2">
                            <i class="fa-brands fa-google"></i> Conectar con Google Calendar
                        </button>
                    </div>
                </div>

                <!-- Resumen de Cargas -->
                <div class="bg-white/90 p-4 rounded-2xl border border-[#dfd5be] shadow-sm space-y-4">
                    <h3 class="text-xs font-bold text-slate-700 uppercase tracking-wider planner-header"><i class="fa-solid fa-chart-line text-[#1f4e79] mr-2"></i>Horas de la Semana</h3>
                    <div class="space-y-4" id="stats-bars-container"></div>
                </div>

                <!-- Ayuda para Instalar en el Celular -->
                <div class="bg-white/90 p-5 rounded-2xl border border-[#dfd5be] shadow-sm space-y-3">
                    <h3 class="text-xs font-bold text-slate-700 uppercase tracking-wider planner-header"><i class="fa-solid fa-mobile-screen-button text-[#1f4e79] mr-2"></i>¿Cómo usarla en tu Celular?</h3>
                    <ol class="list-decimal list-inside text-xs text-slate-500 space-y-2 leading-relaxed">
                        <li>Sube este archivo HTML a <strong>GitHub Pages</strong> o <strong>Vercel</strong> de forma gratuita.</li>
                        <li>Abre el enlace en el navegador de tu móvil (Safari en iPhone o Chrome en Android).</li>
                        <li>Selecciona <strong>"Compartir"</strong> y luego elige <strong>"Añadir a pantalla de inicio"</strong>.</li>
                        <li>¡La app se abrirá en pantalla completa y se sincronizará al instante con tu PC!</li>
                    </ol>
                </div>
            </div>

        </main>

        <!-- BOTÓN FLOTANTE AGREGAR -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30">
            <button onclick="openAddEventModal()" class="bg-[#1f4e79] hover:bg-[#1a4165] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-blue-900/30 border-4 border-[#f5eedf] transition transform active:scale-95">
                <i class="fa-solid fa-plus text-xl"></i>
            </button>
        </div>

        <!-- MODAL: AGREGAR / EDITAR ACTIVIDAD -->
        <div id="add-event-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
            <div class="bg-[#fbfbf9] border border-[#dfd5be] w-full max-w-sm rounded-3xl shadow-2xl p-6 space-y-4">
                <div class="flex justify-between items-center border-b border-slate-100 pb-3">
                    <h3 id="modal-title" class="text-sm font-bold text-slate-900 uppercase tracking-wider planner-header">Nueva Actividad</h3>
                    <button onclick="closeAddEventModal()" class="text-slate-400 hover:text-slate-800"><i class="fa-solid fa-xmark text-lg"></i></button>
                </div>

                <form id="event-form" onsubmit="saveEvent(event)" class="space-y-3.5 text-xs">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Nombre de la actividad</label>
                        <input type="text" id="event-title" required placeholder="Ej: Clase UNIR o Terapias" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800 focus:outline-none focus:border-[#1f4e79]">
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Categoría de horario</label>
                        <select id="event-type" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800 focus:outline-none focus:border-[#1f4e79]">
                            <option value="ESTUDIO">🔵 ESTUDIO</option>
                            <option value="TRABAJO">🔴 TRABAJO (Terapias)</option>
                            <option value="CASA">🟢 CASA (Logística / Limpieza)</option>
                            <option value="DISPONIBLE">🟡 DISPONIBLE (Tiempo Libre)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Fecha</label>
                        <input type="date" id="event-date" required class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800 focus:outline-none focus:border-[#1f4e79]">
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Hora Inicio</label>
                            <input type="time" id="event-start" required class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800 focus:outline-none focus:border-[#1f4e79]">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Duración (Mins)</label>
                            <input type="number" id="event-duration" required min="10" max="480" value="60" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800 focus:outline-none focus:border-[#1f4e79]">
                        </div>
                    </div>

                    <div class="flex flex-col gap-2 pt-2">
                        <div class="flex gap-2">
                            <button type="button" onclick="closeAddEventModal()" class="flex-1 bg-slate-100 text-slate-600 font-bold py-3 rounded-xl">Cancelar</button>
                            <button type="submit" class="flex-1 bg-[#1f4e79] text-white font-bold py-3 rounded-xl shadow-md">Guardar</button>
                        </div>
                        <button type="button" id="modal-delete-btn" onclick="deleteCurrentEvent()" class="w-full bg-red-100 text-red-700 hover:bg-red-200 font-bold py-2.5 rounded-xl transition hidden">
                            <i class="fa-regular fa-trash-can mr-1.5"></i> Eliminar Actividad
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MODAL: EXPORTADOR PREMIUM (IMAGEN DE AGENDA DE LUJO SOBRE MESA) -->
        <div id="export-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-md">
            <div class="bg-[#fbfbf9] border border-slate-200 w-full max-w-sm rounded-3xl shadow-2xl p-6 space-y-4">
                <div class="flex justify-between items-center border-b border-slate-200 pb-3">
                    <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider planner-header"><i class="fa-solid fa-images text-[#1f4e79] mr-2"></i>Imprimir / Exportar</h3>
                    <button onclick="closeExportModal()" class="text-slate-400 hover:text-slate-800"><i class="fa-solid fa-xmark text-lg"></i></button>
                </div>

                <div class="space-y-4 text-xs">
                    <p class="text-slate-500 leading-relaxed">Genera un documento que simula una hermosa **agenda de papel marfil con espirales físicos** reposando sobre un escritorio de madera noble, ideal para imprimir o guardar en HD.</p>
                    
                    <div class="space-y-1.5">
                        <label class="block text-[10px] font-bold text-slate-500 uppercase">Selección de vista</label>
                        <select id="export-view-select" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-slate-800">
                            <option value="week">Semana Actual (Matriz Completa)</option>
                            <option value="month">Mes de Junio (Cuadrícula Completa)</option>
                        </select>
                    </div>

                    <!-- MOCKUP OCULTO DE EXPORTACIÓN (Estética de Agenda Física Premium de la Imagen) -->
                    <div id="capture-container" class="hidden w-[950px] bg-[#221c16] p-12 shadow-2xl relative" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                        
                        <!-- Espirales de Agenda Superior -->
                        <div class="absolute top-[32px] left-[10%] right-[10%] flex justify-between px-8 z-30 pointer-events-none">
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                            <span class="w-4 h-10 spiral-ring"></span>
                        </div>

                        <!-- Hoja de Papel Marfil Realista -->
                        <div class="bg-[#faf5e8] rounded-3xl p-10 border border-[#dfd5be] shadow-inner relative overflow-hidden pt-12" style="background-image: radial-gradient(#dfd7c2 1.2px, transparent 0); background-size: 28px 28px;">
                            
                            <!-- Cabecera de Agenda -->
                            <div class="flex justify-between items-end border-b-2 border-[#1f4e79] pb-6 mb-6">
                                <div>
                                    <h4 class="text-3xl font-bold text-[#1f4e79] tracking-tight planner-header" style="font-family: 'Playfair Display', serif;">FamilySync Agenda Planner</h4>
                                    <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Planificación Unificada del Hogar y Maestría UNIR</p>
                                </div>
                                <div class="text-right">
                                    <span class="text-xs font-bold text-[#385723] bg-[#e2f0d9] border border-[#a9d18e] px-4 py-1.5 rounded-full uppercase" id="capture-sub-tag">Junio 2026</span>
                                </div>
                            </div>

                            <!-- Contenedor del renderizado -->
                            <div id="capture-render-area" class="space-y-4"></div>

                            <!-- Leyenda elegante en el pie -->
                            <div class="mt-8 pt-6 border-t border-slate-200 flex justify-between items-center text-[10px] text-slate-500 font-semibold">
                                <div class="flex gap-4">
                                    <span>🟢 Casa / Logística</span>
                                    <span>🔵 Estudio Académico</span>
                                    <span>🔴 Terapias / Trabajo</span>
                                </div>
                                <span>FamilySync Agenda • Albert & Katerine</span>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div class="space-y-2 pt-2">
                        <button onclick="generateImage()" class="w-full bg-[#1f4e79] hover:bg-[#1a4165] text-white font-bold py-3.5 rounded-xl transition flex items-center justify-center gap-2 shadow-md">
                            <i class="fa-solid fa-image"></i> Descargar Imagen PNG Premium
                        </button>
                        <button onclick="window.print()" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-800 font-bold py-3.5 rounded-xl transition flex items-center justify-center gap-2">
                            <i class="fa-solid fa-file-pdf"></i> Guardar como PDF / Imprimir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTENEDOR DE NOTIFICACIONES TOAST -->
        <div id="toast-container" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2 w-full max-w-xs"></div>
    </div>

    <!-- CÓDIGO LOGÍSTICO, CONEXIÓN CON FIREBASE Y GOOGLE CALENDAR -->
    <script type="module">
        // Importación oficial de módulos de Firebase 11.6.1
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
